DEBUG=1

# CORS (comma-separated values)
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=1
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fastapi_base
DB_CONNECT_MAX_RETRIES=5
DB_CONNECT_RETRY_DELAY=2.0

# Redis (distributed locks)
REDIS_URL=redis://localhost:6379/0
REDIS_CONNECT_MAX_RETRIES=5
REDIS_CONNECT_RETRY_DELAY=2.0
REDIS_LOCK_TIMEOUT=10.0
REDIS_LOCK_BLOCKING_TIMEOUT=10.0

# JWT
JWT_SECRET_KEY=change-me-to-a-secure-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
